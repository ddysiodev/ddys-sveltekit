{
  "name": "ddys-sveltekit",
  "version": "0.1.1",
  "description": "Official SvelteKit integration for the DDYS API with hooks, load helpers, route handlers, Svelte components, caching, SEO helpers, diagnostics, and request form.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://www.npmjs.com/package/ddys-sveltekit",
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "git+https://github.com/ddysiodev/ddys-sveltekit.git" },
  "bugs": { "url": "https://github.com/ddysiodev/ddys-sveltekit/issues" },
  "keywords": ["ddys", "sveltekit", "svelte", "load", "hooks", "route-handlers", "seo", "movies", "video", "api"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "svelte": "./dist/index.js", "import": "./dist/index.js" },
    "./client": { "types": "./dist/client/index.d.ts", "import": "./dist/client/index.js" },
    "./server": { "types": "./dist/server/index.d.ts", "import": "./dist/server/index.js" },
    "./routes": { "types": "./dist/routes/index.d.ts", "import": "./dist/routes/index.js" },
    "./components": { "types": "./dist/components/index.d.ts", "svelte": "./dist/components/index.js", "import": "./dist/components/index.js" },
    "./types": { "types": "./dist/types/ddys.d.ts", "import": "./dist/types/ddys.js" },
    "./styles.css": "./dist/styles/ddys.css"
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "examples", "public", "README.md", "README.zh-CN.md", "LICENSE", ".env.example", "svelte.config.example.js"],
  "sideEffects": ["./dist/styles/ddys.css", "./dist/components/*.svelte"],
  "peerDependencies": {
    "@sveltejs/kit": ">=2.0.0 <3.0.0",
    "svelte": ">=5.0.0 <6.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^24.0.0",
    "svelte": "^5.56.4",
    "typescript": "^5.9.0",
    "vite": "^8.1.3"
  },
  "scripts": {
    "build": "svelte-package",
    "check": "node tools/check.mjs",
    "prepack": "svelte-package",
    "test": "node tools/check.mjs && node --test tests/*.test.mjs",
    "typecheck": "svelte-kit sync && svelte-package && tsc --noEmit"
  },
  "engines": { "node": ">=20.0.0" }
}
